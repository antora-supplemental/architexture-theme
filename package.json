{
  "name": "@amdphreak/architexture-theme-antora",
  "version": "0.1.1",
  "packageManager": "pnpm@10.33.0",
  "description": "DEPRECATED on npm — use GitHub release ui-bundle.zip. See README.md.",
  "deprecated": "Retired: do not install. Pin ui.bundle.url to https://github.com/antora-supplemental/architexture-theme/releases/download/v0.1.0/ui-bundle.zip — docs: https://antora-supplemental.github.io/architexture-theme/architexture-theme/guide/npm-deprecation.html",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i src/styles/tailwind.css -o supplemental-ui/css/site-extra.css",
    "watch:css": "tailwindcss -i src/styles/tailwind.css -o supplemental-ui/css/site-extra.css --watch",
    "build": "pnpm build:css && antora antora-playbook.yml"
  },
  "files": [
    "supplemental-ui"
  ],
  "keywords": [
    "antora",
    "theme",
    "architectural",
    "minimalist",
    "documentation"
  ],
  "author": "Ryan Johnson (AMDphreak)",
  "license": "MIT",
  "homepage": "https://github.com/antora-supplemental/architexture-theme#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antora-supplemental/architexture-theme.git"
  },
  "bugs": {
    "url": "https://github.com/antora-supplemental/architexture-theme/issues"
  },
  "devDependencies": {
    "@antora/cli": "^3.1.9",
    "@antora/lunr-extension": "1.0.0-alpha.12",
    "@antora/site-generator": "^3.1.9",
    "@asciidoctor/tabs": "^1.0.0-beta.6",
    "@tailwindcss/cli": "^4.2.2",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2"
  }
}
